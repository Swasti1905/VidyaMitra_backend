# Normalize line endings to LF in the repository
* text=auto eol=lf

# Python files
*.py text eol=lf

# JSON / YAML / TOML
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Text files
*.txt text eol=lf
*.md text eol=lf
*.env text eol=lf

# Binary files - don't touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
